import express from "express";
import { handleMessage } from "./message";

const app = express();
app.use(express.json());

app.post("/message", async (req, res) => {
  const { message, userId } = req.body;

  const reply = await handleMessage(userId, message);

  res.json({ reply });
});

app.listen(3000, () => {
  console.log("API running on 3000");
});import { db } from "./db";
import { generateAI } from "./ai";

export async function handleMessage(userId: string, message: string) {
  const history = await db.message.findMany({
    where: { userId }
  });

  const context = history.map(m => `${m.role}: ${m.text}`).join("\n");

  const reply = await generateAI(context, message);

  await db.message.createMany({
    data: [
      { userId, role: "user", text: message },
      { userId, role: "assistant", text: reply }
    ]
  });

  return reply;
}export async function generateAI(context: string, message: string) {
  const res = await fetch("https://api.openai.com/v1/chat/completions", {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${process.env.OPENAI_API_KEY}`,
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: "gpt-4o-mini",
      messages: [
        { role: "system", content: "You are a business assistant." },
        { role: "user", content: context + "\nUser: " + message }
      ]
    })
  });

  const data = await res.json();

  return data.choices[0].message.content;
}import { PrismaClient } from "@prisma/client";

export const db = new PrismaClient();
